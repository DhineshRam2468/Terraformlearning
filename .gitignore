# Terraform state (always remote after Week 5)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Secret values — NEVER commit
#terraform.tfvars
*.tfvars
!*.tfvars.example       # example files are safe to commit
!environments/**/*.tfvars  # environment overrides can be committed (no secrets)

# SSH private keys generated by virtualmachine module
scripts/ssh_keys/

# OS noise
.DS_Store
Thumbs.db
